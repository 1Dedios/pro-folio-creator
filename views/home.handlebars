<h1>Welcome to Profolio!</h1>
<p>Begin creating your personal portfolio quickly and intuitively.</p>

<div class="home-buttons">
    <a href="/create" class="button-create">Create Portfolio!</a>
    <a href="/signup" class="button-signup">Sign Up</a>
    <a href="/login" class="button-login">Log In</a>
    {{#if demoUserId}}
    <a href="/profile/{{demoUserId}}" class="button-profile">View Demo Profile</a>
    {{else}}
    <a href="#" class="button-profile disabled">View Demo Profile (no user)</a>
    {{/if}}
    <a href="/portfolios/examples" class="button-examples">View Some Examples</a>
</div>

<section class="features">
    <h2>Features</h2>
    <ul>
        <li>Pre-formatted sections</li>
        <li>Theme customization system</li>
        <li>Super flexible page layouts</li>
        <li>User profile and portfolio dashboard</li>
    </ul>
</section>